# ============================================================
# Copy this file to .env and fill in your values
# cp .env.example .env
# ============================================================

# LLM Provider: 'github', 'openai', or 'anthropic'
LLM_PROVIDER=github

# API Keys — set only the one matching your provider
GITHUB_API_KEY=your_github_personal_access_token_here
# OPENAI_API_KEY=your_openai_api_key_here
# ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Hybrid Detection Settings
CONFIDENCE_THRESHOLD=0.992
LLM_ENABLED=true
MAX_LLM_RETRIES=3
LLM_TIMEOUT=10

# Testing Mode — set to false in production to reduce false positives
TESTING_MODE=true

# Model Paths (relative to project root)
MODEL_PATH=models/best_model.pkl
SCALER_PATH=data/scaler.pkl
LABEL_ENCODER_PATH=data/label_encoder.pkl
FEATURE_COLUMNS_PATH=data/feature_columns.npy
