# ============================================================
# Environment variables — CONTAINS SECRETS, NEVER COMMIT
# ============================================================
.env

# ============================================================
# Python
# ============================================================
__pycache__/
*.py[cod]
*$py.class
*.so
*.pyd
.Python
build/
dist/
*.egg-info/

# ============================================================
# Virtual environment
# ============================================================
venv/
env/
.venv/
ENV/

# ============================================================
# IDE / Editor
# ============================================================
.vscode/
.idea/
*.swp
*.swo
*.suo
*.user

# ============================================================
# Large dataset files (download separately — see README)
# ============================================================
*.csv
data/X_train.npy
data/X_test.npy
data/X_val.npy
data/y_train.npy
data/y_test.npy
data/y_val.npy

# ============================================================
# Trained model binaries (regenerable via model_training.py)
# ============================================================
models/*.pkl
models/best_model.pkl

# ============================================================
# Preprocessed artifacts (regenerable via preprocessing.py)
# Keep feature_columns.npy, scaler.pkl, label_encoder.pkl
# so users can run inference without full retraining
# ============================================================
data/scaler.pkl
data/label_encoder.pkl

# ============================================================
# Temporary / output files
# ============================================================
*.log
*.txt
benchmark_output.txt
benchmark_results.txt
query

